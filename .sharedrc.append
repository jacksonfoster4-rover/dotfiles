export DOTFILES_PATH="/workspaces/.codespaces/.persistedshare/dotfiles"
alias start_rxn="(cd src/frontend/reactNativeApp && pnpm start)"
alias preload_rxn="curl -o /dev/null 'http://localhost:8081/index.bundle?platform=ios&dev=true&lazy=true&minify=false&inlineSourceMap=false&modulesOnly=false&runModule=true&excludeSource=true&sourcePaths=url-server&app=com.rover.Rover-com' \
-H 'Host: localhost:8081' \
-H 'Connection: keep-alive' \
-H 'Accept: multipart/mixed' \
-H 'User-Agent: Rover.com/3 CFNetwork/1474 Darwin/25.3.0' \
-H 'Accept-Language: en-US,en;q=0.9'"
alias makeschemas="m generate_api_schemas && (cd src/frontend/rsdk && pnpm run build:apiClient)"
alias followlogs="dc logs -f -n 20"
alias fetchandreset="git fetch && git reset --hard origin/master"
alias restartcontainers="dc down && dc up -d"
alias msp="m shell_plus"
# Pull the latest dotfiles and re-run the installer (updates nvim config +
# plugins). Runs install.sh from the repo root since it relies on $(pwd).
reload_dotfiles() {
  # +Lazy! sync updates plugins; +TSUpdateSync recompiles every treesitter
  # parser against the running nvim's ABI. The Sync variant blocks (plain
  # +TSUpdate is async and would lose the race against install.sh's +qa),
  # so parsers never go stale after a nvim upgrade — a stale parser is what
  # throws "attempt to call method 'range' (a nil value)" in the highlighter.
  git -C "$DOTFILES_PATH" pull --ff-only &&
    (cd "$DOTFILES_PATH" && ./install.sh "+Lazy! sync" "+TSUpdateSync") || return
  # Reload the current shell's rc so new aliases/functions are picked up now.
  if [ -n "$ZSH_VERSION" ]; then
    source ~/.zshrc
  elif [ -n "$BASH_VERSION" ]; then
    source ~/.bashrc
  fi
}
alias staging="k9s --context staging-a"
# Start (or reattach to) a persistent tmux session running `claude --worktree`.
# Because tmux runs on the box, the session survives SSH disconnects — reconnect
# and re-run to land back in the same Claude session.
# Session name is "<prefix>-<ID>" (ID defaults to 0, but can be any text), so you
# can run several in parallel. The prefix is "tmux-claude", or — inside a
# Codespace ($CODESPACE_NAME set) — the codespace name with its trailing random
# segment (everything after the last "-") stripped, so sessions are grouped per
# codespace. The session is created (detached, in the background) if it doesn't
# already exist; nothing steals your terminal unless you ask to attach. The name
# is also passed to `claude --worktree <name>` so the git worktree lands at a
# predictable path (.claude/worktrees/<name>) and can be pruned on delete.
#   claude_worktree -d 2         create <prefix>-2 in the background, don't attach
#   claude_worktree -a 2         create if needed, then attach to <prefix>-2
#   claude_worktree -d 2 -b 1    background session <prefix>-2, but run claude inside EXISTING worktree <prefix>-1
#   claude_worktree --delete 2   kill <prefix>-2 and prune its worktree (ID required)
#   claude_worktree --delete --force 2   also discard the worktree's uncommitted changes
#   claude_worktree cd 2         cd into <prefix>-2's worktree dir (must exist)
# -a is the default when no flag is given.
claude_worktree() {
  # Session-name prefix. Default "tmux-claude", but inside a Codespace use the
  # codespace name with its trailing random segment stripped. "${VAR%-*}" is a
  # shell parameter expansion: it removes the shortest match of "-*" from the
  # end, i.e. everything after (and including) the last "-".
  local prefix="tmux-claude"
  [[ -n "$CODESPACE_NAME" ]] && prefix="${CODESPACE_NAME%-*}"

  # The MAIN worktree root — where all the .claude/worktrees/* copies live.
  # NOT `git rev-parse --show-toplevel`: that returns whichever worktree you're
  # standing in, so running cwt from inside a linked worktree would point every
  # lookup below at the wrong place (its .claude/worktrees is empty). `git
  # worktree list --porcelain` returns the same set from anywhere in the repo
  # and always prints the main worktree first; awk grabs that first path and
  # exits. Empty (harmless) when we're not inside a git repo at all.
  local root
  root="$(git worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2; exit}')"

  # `cwt -h` / `--help`: print usage and stop. The heredoc (<<EOF) prints every
  # line verbatim up to the closing EOF; \` escapes the backtick so it's literal.
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    cat <<EOF
claude_worktree (alias: cwt) — manage tmux sessions running \`claude --worktree\`.
Session name is "$prefix-<ID>" (ID defaults to 0).

Usage:
  cwt [-a|-d] [ID]              create session <prefix>-ID; -a attach (default), -d background
  cwt [-a|-d] ID -b BASE_ID    session <prefix>-ID, but run claude inside EXISTING worktree <prefix>-BASE_ID
  cwt cd ID                    cd into <prefix>-ID's worktree dir (ID required, must exist)
  cwt cd -                     cd back to the main worktree
  cwt ls                       list this prefix's sessions/worktrees and their state
  cwt --delete [--force] ID    kill <prefix>-ID and prune its worktree (ID required)
  cwt -h|--help                show this help
EOF
    return 0
  fi

  # `cwt cd [ID]` / `cwt cd -`: change directory instead of managing sessions.
  if [[ "$1" == "cd" ]]; then
    shift  # drop the "cd" word so $1 is now the ID (or "-")
    if [[ -z "$root" ]]; then
      echo "claude_worktree cd must be run inside a git repo" >&2
      return 1
    fi
    # `cwt cd -`: jump back to the MAIN worktree (e.g. /workspaces/web), not one
    # of the .claude/worktrees/* copies. $root already IS the main worktree.
    if [[ "$1" == "-" ]]; then
      cd "$root"
      return
    fi
    # Otherwise cd into a specific session's worktree. The ID is required — bare
    # `cwt cd` is ambiguous, so error out instead of guessing a default.
    if [[ -z "$1" ]]; then
      echo "claude_worktree cd requires a session ID (e.g. cwt cd 0)" >&2
      return 1
    fi
    local dir="$root/.claude/worktrees/$prefix-$1"
    if [[ ! -d "$dir" ]]; then
      echo "no worktree at $dir" >&2
      return 1
    fi
    cd "$dir"
    return
  fi

  # `cwt ls`: show every entry for this prefix and its state. An entry can be a
  # live tmux session, an on-disk worktree, or both, so we gather IDs from both
  # sources and merge them.
  if [[ "$1" == "ls" ]]; then
    # Two ID sources, one per line:
    #   1. live tmux sessions named "<prefix>-*" (grep the session list)
    #   2. worktree dirs at .claude/worktrees/<prefix>-* (find, so an unmatched
    #      glob can't error out — zsh errors on a literal no-match glob, bash
    #      leaves it literal; find sidesteps both)
    # basename gives us "<prefix>-<id>"; sed strips the "<prefix>-" so we're left
    # with bare IDs, then sort -u de-dupes the union and drops blank lines.
    local ids
    ids="$(
      tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^$prefix-"
      [[ -n "$root" ]] && find "$root/.claude/worktrees" -mindepth 1 -maxdepth 1 -type d -name "$prefix-*" -exec basename {} \; 2>/dev/null
    )"
    ids="$(printf '%s\n' "$ids" | sed "s/^$prefix-//" | sort -u | sed '/^$/d')"
    if [[ -z "$ids" ]]; then
      echo "no $prefix sessions or worktrees"
      return 0
    fi
    printf '%-14s  %-7s  %s\n' ID SESSION WORKTREE
    local id
    # <<< is a here-string (bash + zsh): feed $ids to the loop on stdin. Looping
    # over a pipeline instead would run the body in a subshell in bash.
    while IFS= read -r id; do
      [[ -z "$id" ]] && continue
      local sess="-" wt=""
      # For a live session, don't derive the worktree from the id — just ask
      # tmux where the session's pane actually is. That's correct for both a
      # normal session and a -b session (which runs in another id's worktree, so
      # id-derivation would give the wrong path or nothing).
      if tmux has-session -t "$prefix-$id" 2>/dev/null; then
        sess="live"
        wt="$(tmux display-message -p -t "$prefix-$id" '#{pane_current_path}' 2>/dev/null)"
      fi
      # Dead session (an orphan worktree left on disk) or tmux gave us nothing:
      # fall back to the id-named worktree dir if it exists, else "-".
      if [[ -z "$wt" ]]; then
        if [[ -n "$root" && -d "$root/.claude/worktrees/$prefix-$id" ]]; then
          wt="$root/.claude/worktrees/$prefix-$id"
        else
          wt="-"
        fi
      fi
      printf '%-14s  %-7s  %s\n' "$id" "$sess" "$wt"
    done <<< "$ids"
    return 0
  fi
  # Parse the remaining args. Modes: -a (attach, default) / -d (detached) /
  # --delete. -b/--base <ID> is an OPTION, not a mode: it names an EXISTING
  # worktree to run claude inside, while the positional ID names the tmux
  # session. So `cwt -d 2 -b 1` makes detached session <prefix>-2 running claude
  # inside worktree <prefix>-1. Flags and the positional ID may come in any
  # order, so we loop instead of matching fixed positions.
  local mode=-a base="" force="" id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -a|-d) mode="$1"; shift ;;
      --delete) mode=--delete; shift ;;
      --force) force="--force"; shift ;;  # only meaningful with --delete
      -b|--base)
        base="$2"  # the NEXT arg is the base worktree ID
        if [[ -z "$base" ]]; then
          echo "claude_worktree -b/--base requires a worktree ID" >&2
          return 1
        fi
        shift 2 ;;
      *) id="$1"; shift ;;  # bare arg = the session ID
    esac
  done

  if [[ "$mode" == "--delete" ]]; then
    if [[ -z "$id" ]]; then
      echo "claude_worktree --delete requires a session ID" >&2
      return 1
    fi
    local name="$prefix-$id"
    tmux kill-session -t "$name" 2>/dev/null
    # Only prune a worktree if THIS session owns one. A session made with -b
    # runs inside another session's worktree and has none of its own, so its
    # <prefix>-<id> dir won't exist — skip the remove rather than erroring, and
    # never touch the base session's worktree.
    local dir="$root/.claude/worktrees/$name"
    [[ -n "$root" && -d "$dir" ]] && git worktree remove $force "$dir"
    return 0  # explicit: don't leak the [[ -d ]] test's exit status when a -b session had no worktree
  fi

  # Session name is the positional ID (default 0).
  local name="$prefix-${id:-0}"

  if [[ -n "$base" ]]; then
    # -b/--base: run claude inside an EXISTING worktree (<prefix>-<base>) while
    # the tmux session keeps its own name. Because the worktree name differs
    # from the session name we can't use `claude --worktree <name>` (that would
    # target a worktree named after the SESSION); instead we start the tmux
    # session with its working directory set to the base worktree (tmux's -c)
    # and run plain claude there. Bail if that worktree doesn't already exist —
    # -b never creates one.
    local dir="$root/.claude/worktrees/$prefix-$base"
    if [[ -z "$root" || ! -d "$dir" ]]; then
      echo "no existing worktree at $dir (create one with 'cwt $base')" >&2
      return 1
    fi
    tmux has-session -t "$name" 2>/dev/null ||
      tmux new-session -d -s "$name" -c "$dir" "claude -n $name"
  else
    # Normal create: claude --worktree makes (or reuses) a worktree named after
    # the session.
    tmux has-session -t "$name" 2>/dev/null ||
      tmux new-session -d -s "$name" "claude --worktree $name -n $name"
  fi
  # Attach for -a (the default); -d leaves it running in the background.
  [[ "$mode" == "-a" ]] && tmux attach-session -t "$name"
}
alias cwt="claude_worktree"
