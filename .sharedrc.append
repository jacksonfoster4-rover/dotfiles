export DOTFILES_PATH="/workspaces/.codespaces/.persistedshare/dotfiles"
alias start_rxn="(cd src/frontend/reactNativeApp && pnpm start)"
alias preload_rxn="curl -o /dev/null 'http://localhost:8081/index.bundle?platform=ios&dev=true&lazy=true&minify=false&inlineSourceMap=false&modulesOnly=false&runModule=true&excludeSource=true&sourcePaths=url-server&app=com.rover.Rover-com' \
-H 'Host: localhost:8081' \
-H 'Connection: keep-alive' \
-H 'Accept: multipart/mixed' \
-H 'User-Agent: Rover.com/3 CFNetwork/1474 Darwin/25.3.0' \
-H 'Accept-Language: en-US,en;q=0.9'"
alias makeschemas="m generate_api_schemas && (cd src/frontend/rsdk && pnpm run build:apiClient)"
alias followlogs="dc logs -f -n 20"
alias fetchandreset="git fetch && git reset --hard origin/master"
alias restartcontainers="dc down && dc up -d"
alias msp="m shell_plus"
# Pull the latest dotfiles and re-run the installer (updates nvim config +
# plugins). Runs install.sh from the repo root since it relies on $(pwd).
reload_dotfiles() {
  # +Lazy! sync updates plugins; +TSUpdateSync recompiles every treesitter
  # parser against the running nvim's ABI. The Sync variant blocks (plain
  # +TSUpdate is async and would lose the race against install.sh's +qa),
  # so parsers never go stale after a nvim upgrade — a stale parser is what
  # throws "attempt to call method 'range' (a nil value)" in the highlighter.
  git -C "$DOTFILES_PATH" pull --ff-only &&
    (cd "$DOTFILES_PATH" && ./install.sh "+Lazy! sync" "+TSUpdateSync") || return
  # Reload the current shell's rc so new aliases/functions are picked up now.
  if [ -n "$ZSH_VERSION" ]; then
    source ~/.zshrc
  elif [ -n "$BASH_VERSION" ]; then
    source ~/.bashrc
  fi
}
alias staging="k9s --context staging-a"
# Start (or reattach to) a persistent tmux session running `claude --worktree`.
# Because tmux runs on the box, the session survives SSH disconnects — reconnect
# and re-run to land back in the same Claude session.
# Session name is "<prefix>-<ID>" (ID defaults to 0, but can be any text), so you
# can run several in parallel. The prefix is "tmux-claude", or — inside a
# Codespace ($CODESPACE_NAME set) — the codespace name with its trailing random
# segment (everything after the last "-") stripped, so sessions are grouped per
# codespace. The session is created (detached, in the background) if it doesn't
# already exist; nothing steals your terminal unless you ask to attach. The name
# is also passed to `claude --worktree <name>` so the git worktree lands at a
# predictable path (.claude/worktrees/<name>) and can be pruned on delete.
#   claude_worktree -d 2         create <prefix>-2 in the background, don't attach
#   claude_worktree -a 2         create if needed, then attach to <prefix>-2
#   claude_worktree --delete 2   kill <prefix>-2 and prune its worktree (ID required)
#   claude_worktree --delete --force 2   also discard the worktree's uncommitted changes
#   claude_worktree cd 2         cd into <prefix>-2's worktree dir (must exist)
# -a is the default when no flag is given.
claude_worktree() {
  # Session-name prefix. Default "tmux-claude", but inside a Codespace use the
  # codespace name with its trailing random segment stripped. "${VAR%-*}" is a
  # shell parameter expansion: it removes the shortest match of "-*" from the
  # end, i.e. everything after (and including) the last "-".
  local prefix="tmux-claude"
  [[ -n "$CODESPACE_NAME" ]] && prefix="${CODESPACE_NAME%-*}"

  # `cwt -h` / `--help`: print usage and stop. The heredoc (<<EOF) prints every
  # line verbatim up to the closing EOF; \` escapes the backtick so it's literal.
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    cat <<EOF
claude_worktree (alias: cwt) — manage tmux sessions running \`claude --worktree\`.
Session name is "$prefix-<ID>" (ID defaults to 0).

Usage:
  cwt [-a|-d] [ID]              create session <prefix>-ID; -a attach (default), -d background
  cwt cd ID                    cd into <prefix>-ID's worktree dir (ID required, must exist)
  cwt cd -                     cd back to the main worktree
  cwt --delete [--force] ID    kill <prefix>-ID and prune its worktree (ID required)
  cwt -h|--help                show this help
EOF
    return 0
  fi

  # `cwt cd [ID]` / `cwt cd -`: change directory instead of managing sessions.
  if [[ "$1" == "cd" ]]; then
    shift  # drop the "cd" word so $1 is now the ID (or "-")
    # --show-toplevel = the root of the worktree we're currently in. Empty (and
    # 2>/dev/null hides the error) when we're not inside a git repo at all.
    local root
    root="$(git rev-parse --show-toplevel 2>/dev/null)"
    if [[ -z "$root" ]]; then
      echo "claude_worktree cd must be run inside a git repo" >&2
      return 1
    fi
    # `cwt cd -`: jump back to the MAIN worktree (e.g. /workspaces/web), not one
    # of the .claude/worktrees/* copies. `git worktree list --porcelain` always
    # lists the main worktree first; awk grabs the path from that first
    # "worktree <path>" line and exits immediately.
    if [[ "$1" == "-" ]]; then
      local main
      main="$(git worktree list --porcelain | awk '/^worktree /{print $2; exit}')"
      cd "$main"
      return
    fi
    # Otherwise cd into a specific session's worktree. The ID is required — bare
    # `cwt cd` is ambiguous, so error out instead of guessing a default.
    if [[ -z "$1" ]]; then
      echo "claude_worktree cd requires a session ID (e.g. cwt cd 0)" >&2
      return 1
    fi
    local dir="$root/.claude/worktrees/$prefix-$1"
    if [[ ! -d "$dir" ]]; then
      echo "no worktree at $dir" >&2
      return 1
    fi
    cd "$dir"
    return
  fi
  local mode=-a
  case "$1" in
    -a|-d|--delete) mode="$1"; shift ;;
  esac
  if [[ "$mode" == "--delete" ]]; then
    local force="" id=""
    for arg in "$@"; do
      case "$arg" in
        --force) force="--force" ;;
        *) id="$arg" ;;
      esac
    done
    if [[ -z "$id" ]]; then
      echo "claude_worktree --delete requires a session ID" >&2
      return 1
    fi
    local name="$prefix-$id"
    tmux kill-session -t "$name" 2>/dev/null
    local root
    root="$(git rev-parse --show-toplevel 2>/dev/null)"
    [[ -n "$root" ]] && git worktree remove $force "$root/.claude/worktrees/$name"
    return
  fi
  local name="$prefix-${1:-0}"
  tmux has-session -t "$name" 2>/dev/null ||
    tmux new-session -d -s "$name" "claude --worktree $name -n $name"
  [[ "$mode" == "-a" ]] && tmux attach-session -t "$name"
}
alias cwt="claude_worktree"
